generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  SALES
  ACCOUNTING
  SUPPORT
  READ_ONLY
  PORTAL_USER
}

enum RecordStatus {
  ACTIVE
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  NURTURE
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  NEEDS_ANALYSIS
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  COST_OF_GOODS_SOLD
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum AccountingProviderType {
  CLEARKEY
  QUICKBOOKS
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTING
  ACTIVE
  ERROR
  REAUTH_REQUIRED
}

enum SyncDirection {
  PUSH
  PULL
  BIDIRECTIONAL
}

enum PayrollMode {
  EMBEDDED
  CONNECTED_PROVIDER
}

enum EmploymentStatus {
  DRAFT
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum PayrollRunStatus {
  DRAFT
  CALCULATING
  NEEDS_APPROVAL
  APPROVED
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum BillingTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  MANUAL_QUOTE_REQUIRED
}

model Organization {
  id                         String                      @id @default(uuid()) @db.Uuid
  name                       String
  slug                       String                      @unique
  orgCode                    String                      @unique
  legalName                  String?
  timezone                   String                      @default("America/Chicago")
  defaultCurrency            String                      @default("USD")
  status                     RecordStatus                @default(ACTIVE)
  accountingProvider         AccountingProviderType      @default(CLEARKEY)
  clerkOrganizationId        String?                     @unique
  stripeCustomerId           String?                     @unique
  stripeSubscriptionId       String?                     @unique
  stripeSubscriptionStatus   String?
  stripeConnectedAccountId   String?                     @unique
  billingTier                BillingTier                 @default(STARTER)
  billingStatus              BillingStatus               @default(TRIALING)
  pricingVersion             String                      @default("2026-v1")
  pricingOverrideEnabled     Boolean                     @default(false)
  pricingOverrideAmountCents Int?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  publicId                   String                      @unique @default(cuid())
  operationalStatus          String                      @default("ACTIVE")
  memberships                OrganizationMembership[]
  theme                      OrganizationTheme?
  accounts                   CrmAccount[]
  contacts                   Contact[]
  leads                      Lead[]
  deals                      Deal[]
  tasks                      Task[]
  activities                 Activity[]
  cases                      SupportCase[]
  products                   Product[]
  invoices                   Invoice[]
  payments                   Payment[]
  vendors                    Vendor[]
  bills                      Bill[]
  expenses                   Expense[]
  ledgerAccounts             LedgerAccount[]
  journalEntries             JournalEntry[]
  integrations               Integration[]
  auditLogs                  AuditLog[]
  auditChainHead             AuditChainHead?
  domains                    OrganizationDomain[]
  webhookEvents              WebhookEvent[]
  customFieldDefinitions     CustomFieldDefinition[]
  automationRules            AutomationRule[]
  files                      StoredFile[]
  bookings                   Booking[]
  notes                      Note[]
  notifications              Notification[]
  taxRates                   TaxRate[]
  taxDocuments               TaxDocument[]
  automationRuns             AutomationRun[]
  reconciliationSessions     ReconciliationSession[]
  accountingPeriods          AccountingPeriod[]
  departments                Department[]
  employees                  Employee[]
  payrollConnection          PayrollConnection?
  payrollRuns                PayrollRun[]
  timeEntries                TimeEntry[]
  timeOffRequests            TimeOffRequest[]
  benefits                   Benefit[]
  campaigns                  Campaign[]
  calendarEvents             CalendarEvent[]
  bankAccounts               BankAccount[]
  bankTransactions           BankTransaction[]
  savedViews                 SavedView[]
  emailTemplates             EmailTemplate[]
  emailMessages              EmailMessage[]
  endpointPages              EndpointPage[]
  endpointSubmissions        EndpointSubmission[]
  moduleConfiguration        OrganizationModule?
  usage                      OrganizationUsage?
  websites                   Website[]
  managedMailboxes           ManagedMailbox[]
  billingAuditLogs           BillingAuditLog[]
  collaborationChannels      CollaborationChannel[]
  supportTickets             PlatformSupportTicket[]
  paymentProviderConnections PaymentProviderConnection[]
  paymentTransactions        PaymentTransaction[]
  tenantSettings             TenantSettings?
  adminActions               AdminActionLog[]
  oauthStates                OAuthState[]
  aiConversations            AiConversation[]
  dataLinks                  DataLink[]
  storagePolicies            StoragePolicy[]

  @@index([status])
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  clerkUserId             String                   @unique
  email                   String                   @unique
  firstName               String?
  lastName                String?
  platformAdmin           Boolean                  @default(false)
  adminRole               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  memberships             OrganizationMembership[]
  createdTasks            Task[]                   @relation("TaskCreator")
  assignedTasks           Task[]                   @relation("TaskAssignee")
  auditLogs               AuditLog[]
  collaborationMessages   CollaborationMessage[]
  platformSupportMessages PlatformSupportMessage[]
  adminActions            AdminActionLog[]
  aiConversations         AiConversation[]
}

model TenantSettings {
  organizationId   String       @id @db.Uuid
  profileJson      Json         @default("{}")
  bookingJson      Json         @default("{}")
  portalJson       Json         @default("{}")
  notificationJson Json         @default("{}")
  securityJson     Json         @default("{}")
  accountingJson   Json         @default("{}")
  inventoryJson    Json         @default("{}")
  workforceJson    Json         @default("{}")
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CollaborationChannel {
  id             String                 @id @default(uuid()) @db.Uuid
  publicId       String                 @unique @default(cuid())
  organizationId String                 @db.Uuid
  name           String
  description    String?
  channelType    String                 @default("INTERNAL")
  visibility     String                 @default("MEMBERS")
  relatedType    String?
  relatedId      String?                @db.Uuid
  videoRoomKey   String?                @unique
  archivedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       CollaborationMessage[]

  @@unique([organizationId, name])
  @@index([organizationId, channelType, archivedAt])
}

model CollaborationMessage {
  id           String               @id @default(uuid()) @db.Uuid
  publicId     String               @unique @default(cuid())
  channelId    String               @db.Uuid
  authorUserId String?              @db.Uuid
  contactId    String?              @db.Uuid
  body         String
  messageType  String               @default("TEXT")
  metadata     Json                 @default("{}")
  editedAt     DateTime?
  deletedAt    DateTime?
  createdAt    DateTime             @default(now())
  channel      CollaborationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author       User?                @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt])
}

model PlatformSupportTicket {
  id              String                   @id @default(uuid()) @db.Uuid
  publicId        String                   @unique @default(cuid())
  organizationId  String                   @db.Uuid
  openedById      String?                  @db.Uuid
  assignedAdminId String?                  @db.Uuid
  subject         String
  category        String                   @default("GENERAL")
  priority        String                   @default("NORMAL")
  status          String                   @default("OPEN")
  metadata        Json                     @default("{}")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  closedAt        DateTime?
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages        PlatformSupportMessage[]

  @@index([organizationId, status, updatedAt])
  @@index([assignedAdminId, status])
}

model PlatformSupportMessage {
  id           String                @id @default(uuid()) @db.Uuid
  ticketId     String                @db.Uuid
  authorUserId String?               @db.Uuid
  authorType   String
  body         String
  internalOnly Boolean               @default(false)
  createdAt    DateTime              @default(now())
  ticket       PlatformSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model PaymentProviderConnection {
  id                    String               @id @default(uuid()) @db.Uuid
  publicId              String               @unique @default(cuid())
  organizationId        String               @db.Uuid
  provider              String
  status                String               @default("DISCONNECTED")
  isDefault             Boolean              @default(false)
  externalAccountId     String?
  merchantId            String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  metadata              Json                 @default("{}")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions          PaymentTransaction[]

  @@unique([organizationId, provider])
  @@index([organizationId, status])
}

model PaymentTransaction {
  id                   String                     @id @default(uuid()) @db.Uuid
  publicId             String                     @unique @default(cuid())
  organizationId       String                     @db.Uuid
  providerConnectionId String?                    @db.Uuid
  provider             String
  invoiceId            String?                    @db.Uuid
  bookingId            String?                    @db.Uuid
  contactId            String?                    @db.Uuid
  amountCents          Int
  currency             String                     @default("USD")
  status               String                     @default("PENDING")
  externalCheckoutId   String?
  externalPaymentId    String?
  checkoutUrl          String?
  providerPayload      Json                       @default("{}")
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerConnection   PaymentProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([provider, externalPaymentId])
}

model AdminActionLog {
  id             String        @id @default(uuid()) @db.Uuid
  actorUserId    String        @db.Uuid
  organizationId String?       @db.Uuid
  action         String
  resourceType   String
  resourceId     String?
  reason         String?
  beforeJson     Json?
  afterJson      Json?
  requestId      String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  actor          User          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model OAuthState {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  provider       String
  nonce          String       @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([provider, expiresAt, usedAt])
}

model OrganizationMembership {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  userId         String         @db.Uuid
  role           MembershipRole
  permissions    String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationTheme {
  id                        String       @id @default(uuid()) @db.Uuid
  organizationId            String       @unique @db.Uuid
  logoUrl                   String?
  faviconUrl                String?
  primaryColor              String       @default("#c9a033")
  accentColor               String       @default("#504a44")
  surfaceColor              String       @default("#ffffff")
  backgroundColor           String       @default("#f5f0e8")
  textColor                 String       @default("#1c1917")
  headingFont               String       @default("Cormorant Garamond")
  bodyFont                  String       @default("Geist")
  borderRadius              Int          @default(12)
  density                   String       @default("comfortable")
  darkMode                  Boolean      @default(false)
  customCss                 String?
  portalHeadline            String?
  portalSubhead             String?
  coverImageUrl             String?
  consoleTitle              String?
  consoleLogoUrl            String?
  consoleBackgroundImageUrl String?
  consolePrimaryColor       String       @default("#c9a033")
  consoleSidebarColor       String       @default("#1c1917")
  consoleBackgroundColor    String       @default("#f5f0e8")
  consoleSurfaceColor       String       @default("#ffffff")
  consoleTextColor          String       @default("#1c1917")
  consoleMutedColor         String       @default("#746c64")
  consoleHeaderColor        String       @default("#ffffff")
  consoleFont               String       @default("Geist")
  consoleRadius             Int          @default(8)
  consoleDensity            String       @default("comfortable")
  consoleNavigationStyle    String       @default("sidebar")
  paymentTitle              String?
  paymentSubtitle           String?
  paymentLogoUrl            String?
  paymentBackgroundImageUrl String?
  paymentPrimaryColor       String       @default("#c9a033")
  paymentHeaderColor        String       @default("#1c1917")
  paymentBackgroundColor    String       @default("#f3eee5")
  paymentSurfaceColor       String       @default("#ffffff")
  paymentTextColor          String       @default("#1c1917")
  paymentMutedColor         String       @default("#746c64")
  paymentFont               String       @default("Geist")
  paymentRadius             Int          @default(16)
  paymentFooterText         String?
  navigationJson            Json         @default("{}")
  pageBlocksJson            Json         @default("[]")
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationDomain {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @db.Uuid
  hostname           String       @unique
  kind               String       @default("CUSTOM")
  status             String       @default("PENDING")
  isPrimary          Boolean      @default(false)
  sslEnabled         Boolean      @default(false)
  cloudflareZoneId   String?
  cloudflareRecordId String?
  verificationToken  String       @unique @default(uuid())
  verifiedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dnsRecords         DnsRecord[]

  @@index([organizationId, status])
}

model OrganizationModule {
  organizationId    String       @id @db.Uuid
  accounting        Boolean      @default(false)
  workforce         Boolean      @default(false)
  scheduling        Boolean      @default(false)
  timeClock         Boolean      @default(false)
  marketing         Boolean      @default(false)
  payroll           Boolean      @default(false)
  advancedAi        Boolean      @default(false)
  advancedAnalytics Boolean      @default(false)
  managedEmail      Boolean      @default(false)
  premiumTemplates  Boolean      @default(false)
  managedDomain     Boolean      @default(false)
  crm               Boolean      @default(true)
  cases             Boolean      @default(true)
  campaigns         Boolean      @default(true)
  banking           Boolean      @default(true)
  websites          Boolean      @default(true)
  domains           Boolean      @default(true)
  automations       Boolean      @default(true)
  reports           Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationUsage {
  organizationId  String       @id @db.Uuid
  licensedUsers   Int          @default(1)
  accountingUsers Int          @default(0)
  workforceUsers  Int          @default(0)
  schedulingUsers Int          @default(0)
  marketingUsers  Int          @default(0)
  mailboxCount    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PricingConfig {
  id             String   @id @default(uuid()) @db.Uuid
  pricingVersion String   @unique
  active         Boolean  @default(false)
  config         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
}

model Website {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @db.Uuid
  slug            String
  defaultHostname String           @unique
  status          String           @default("DRAFT")
  themeJson       Json             @default("{}")
  configJson      Json             @default("{}")
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages           WebsitePage[]
  aiConversations AiConversation[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

model AiConversation {
  id             String       @id @default(uuid()) @db.Uuid
  publicId       String       @unique @default(cuid())
  organizationId String       @db.Uuid
  websiteId      String?      @db.Uuid
  userId         String?      @db.Uuid
  title          String
  contextJson    Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website        Website?     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages       AiMessage[]

  @@index([organizationId, updatedAt])
  @@index([websiteId, updatedAt])
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  role           String
  content        String
  model          String?
  responseId     String?
  usageJson      Json           @default("{}")
  status         String         @default("COMPLETED")
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model DataLink {
  id             String       @id @default(uuid()) @db.Uuid
  publicId       String       @unique @default(cuid())
  organizationId String       @db.Uuid
  sourceType     String
  sourceId       String
  targetType     String
  targetId       String
  relationship   String
  permissions    String[]     @default([])
  metadataJson   Json         @default("{}")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourceType, sourceId, targetType, targetId, relationship])
  @@index([organizationId, sourceType, targetType, active])
}

model StoragePolicy {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  scope            String
  retentionClass   String       @default("STANDARD")
  maxFileSizeBytes BigInt       @default(26214400)
  allowedTypesJson Json         @default("[]")
  publicAssets     Boolean      @default(false)
  versioning       Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope])
  @@index([organizationId, scope])
}

model WebsitePage {
  id          String   @id @default(uuid()) @db.Uuid
  websiteId   String   @db.Uuid
  path        String
  title       String
  seoJson     Json     @default("{}")
  contentJson Json     @default("{}")
  status      String   @default("DRAFT")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([websiteId, path])
  @@index([websiteId, status, sortOrder])
}

model DnsRecord {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationDomainId String             @db.Uuid
  recordType           String
  name                 String
  value                String
  ttl                  Int                @default(1)
  proxied              Boolean            @default(false)
  cloudflareRecordId   String?
  status               String             @default("PENDING")
  lastCheckedAt        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  domain               OrganizationDomain @relation(fields: [organizationDomainId], references: [id], onDelete: Cascade)

  @@unique([organizationDomainId, recordType, name, value])
  @@index([organizationDomainId, status])
}

model ManagedMailbox {
  id                String         @id @default(uuid()) @db.Uuid
  organizationId    String         @db.Uuid
  email             String         @unique
  displayName       String
  provider          String         @default("ZOHO")
  providerMailboxId String?
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  aliases           MailboxAlias[]

  @@index([organizationId, active])
}

model MailboxAlias {
  id        String         @id @default(uuid()) @db.Uuid
  mailboxId String         @db.Uuid
  email     String         @unique
  createdAt DateTime       @default(now())
  mailbox   ManagedMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
}

model BillingAuditLog {
  id                       String        @id @default(uuid()) @db.Uuid
  organizationId           String?       @db.Uuid
  actorUserId              String?
  action                   String
  beforeJson               Json?
  afterJson                Json?
  calculatedTotalCents     Int?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeConnectedAccountId String?
  createdAt                DateTime      @default(now())
  organization             Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model CrmAccount {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @db.Uuid
  name            String
  accountType     String        @default("PROSPECT")
  website         String?
  phone           String?
  industry        String?
  annualRevenue   Decimal?      @db.Decimal(19, 4)
  ownerUserId     String?       @db.Uuid
  parentAccountId String?       @db.Uuid
  billingAddress  Json?
  shippingAddress Json?
  customFields    Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts        Contact[]
  deals           Deal[]
  invoices        Invoice[]
  cases           SupportCase[]

  @@unique([organizationId, name])
  @@index([organizationId, accountType])
}

model Contact {
  id                     String        @id @default(uuid()) @db.Uuid
  organizationId         String        @db.Uuid
  accountId              String?       @db.Uuid
  firstName              String
  lastName               String?
  email                  String?
  phone                  String?
  mobile                 String?
  jobTitle               String?
  lifecycleStatus        String        @default("LEAD")
  preferredContactMethod String?
  emailOptOut            Boolean       @default(false)
  smsOptOut              Boolean       @default(false)
  ownerUserId            String?       @db.Uuid
  customFields           Json          @default("{}")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?
  organization           Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account                CrmAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  deals                  Deal[]        @relation("PrimaryContact")
  invoices               Invoice[]
  activities             Activity[]
  cases                  SupportCase[]
  bookings               Booking[]
  notes                  Note[]

  @@index([organizationId, email])
  @@index([organizationId, accountId])
}

model Lead {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  firstName      String
  lastName       String?
  company        String?
  email          String?
  phone          String?
  source         String?
  status         LeadStatus   @default(NEW)
  rating         String?
  estimatedValue Decimal?     @db.Decimal(19, 4)
  ownerUserId    String?      @db.Uuid
  score          Int          @default(0)
  convertedAt    DateTime?
  customFields   Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, email])
}

model Deal {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  accountId         String?      @db.Uuid
  primaryContactId  String?      @db.Uuid
  name              String
  amount            Decimal      @default(0) @db.Decimal(19, 4)
  currency          String       @default("USD")
  stage             DealStage    @default(PROSPECTING)
  probability       Int          @default(10)
  expectedCloseDate DateTime?
  ownerUserId       String?      @db.Uuid
  nextStep          String?
  lossReason        String?
  customFields      Json         @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  closedAt          DateTime?
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account           CrmAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  primaryContact    Contact?     @relation("PrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  @@index([organizationId, stage])
  @@index([organizationId, expectedCloseDate])
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  title          String
  description    String?
  status         String       @default("OPEN")
  priority       String       @default("NORMAL")
  dueAt          DateTime?
  reminderAt     DateTime?
  relatedType    String?
  relatedId      String?      @db.Uuid
  createdById    String       @db.Uuid
  assignedToId   String?      @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  completedAt    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo     User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])

  @@index([organizationId, status, dueAt])
}

model Activity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  contactId      String?      @db.Uuid
  type           String
  subject        String?
  body           String?
  occurredAt     DateTime     @default(now())
  actorUserId    String?      @db.Uuid
  metadata       Json         @default("{}")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([organizationId, contactId])
}

model SupportCase {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  accountId      String?      @db.Uuid
  contactId      String?      @db.Uuid
  caseNumber     String
  subject        String
  description    String?
  status         String       @default("NEW")
  priority       String       @default("NORMAL")
  ownerUserId    String?      @db.Uuid
  resolution     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  closedAt       DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account        CrmAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([organizationId, caseNumber])
  @@index([organizationId, status])
}

model Campaign {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  name            String
  type            String       @default("EMAIL")
  status          String       @default("DRAFT")
  audienceJson    Json         @default("{}")
  budget          Decimal?     @db.Decimal(19, 4)
  memberCount     Int          @default(0)
  responseCount   Int          @default(0)
  conversionCount Int          @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, status])
}

model CalendarEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  title          String
  description    String?
  eventType      String       @default("MEETING")
  startsAt       DateTime
  endsAt         DateTime
  location       String?
  ownerUserId    String?      @db.Uuid
  relatedType    String?
  relatedId      String?      @db.Uuid
  attendeeJson   Json         @default("[]")
  status         String       @default("CONFIRMED")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startsAt])
}

model Product {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  sku            String?
  name           String
  description    String?
  type           String        @default("SERVICE")
  price          Decimal       @default(0) @db.Decimal(19, 4)
  cost           Decimal       @default(0) @db.Decimal(19, 4)
  quantityOnHand Decimal       @default(0) @db.Decimal(19, 4)
  reorderLevel   Decimal?      @db.Decimal(19, 4)
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems   InvoiceItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, active])
}

model Invoice {
  id              String              @id @default(uuid()) @db.Uuid
  organizationId  String              @db.Uuid
  accountId       String?             @db.Uuid
  contactId       String?             @db.Uuid
  invoiceNumber   String
  status          InvoiceStatus       @default(DRAFT)
  currency        String              @default("USD")
  issueDate       DateTime
  dueDate         DateTime
  subtotal        Decimal             @default(0) @db.Decimal(19, 4)
  discountTotal   Decimal             @default(0) @db.Decimal(19, 4)
  taxTotal        Decimal             @default(0) @db.Decimal(19, 4)
  total           Decimal             @default(0) @db.Decimal(19, 4)
  amountPaid      Decimal             @default(0) @db.Decimal(19, 4)
  balanceDue      Decimal             @default(0) @db.Decimal(19, 4)
  notes           String?
  terms           String?
  publicTokenId   String?             @unique
  postedJournalId String?             @unique @db.Uuid
  externalId      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sentAt          DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account         CrmAccount?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact         Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  allocations     PaymentAllocation[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status, dueDate])
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  productId   String?  @db.Uuid
  description String
  quantity    Decimal  @default(1) @db.Decimal(19, 4)
  unitPrice   Decimal  @db.Decimal(19, 4)
  taxRate     Decimal  @default(0) @db.Decimal(9, 6)
  discount    Decimal  @default(0) @db.Decimal(19, 4)
  lineTotal   Decimal  @db.Decimal(19, 4)
  sortOrder   Int      @default(0)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model Payment {
  id                     String              @id @default(uuid()) @db.Uuid
  organizationId         String              @db.Uuid
  amount                 Decimal             @db.Decimal(19, 4)
  currency               String              @default("USD")
  status                 String
  method                 String?
  referenceNumber        String?
  receivedAt             DateTime
  stripePaymentIntentId  String?             @unique
  stripeChargeId         String?             @unique
  stripeApplicationFeeId String?             @unique
  externalId             String?
  postedJournalId        String?             @unique @db.Uuid
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  allocations            PaymentAllocation[]

  @@index([organizationId, receivedAt])
}

model PaymentAllocation {
  id        String  @id @default(uuid()) @db.Uuid
  paymentId String  @db.Uuid
  invoiceId String  @db.Uuid
  amount    Decimal @db.Decimal(19, 4)
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([paymentId, invoiceId])
}

model Vendor {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  email          String?
  phone          String?
  taxIdEncrypted String?
  eligible1099   Boolean      @default(false)
  address        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bills          Bill[]
  expenses       Expense[]

  @@unique([organizationId, name])
}

model Bill {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  vendorId        String       @db.Uuid
  billNumber      String?
  status          String       @default("DRAFT")
  issueDate       DateTime
  dueDate         DateTime
  total           Decimal      @db.Decimal(19, 4)
  amountPaid      Decimal      @default(0) @db.Decimal(19, 4)
  currency        String       @default("USD")
  postedJournalId String?      @unique @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor          Vendor       @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([organizationId, status, dueDate])
}

model Expense {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  vendorId        String?      @db.Uuid
  description     String
  amount          Decimal      @db.Decimal(19, 4)
  currency        String       @default("USD")
  incurredAt      DateTime
  category        String?
  receiptFileId   String?      @db.Uuid
  postedJournalId String?      @unique @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor          Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([organizationId, incurredAt])
}

model LedgerAccount {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  parentId       String?       @db.Uuid
  code           String
  name           String
  type           AccountType
  active         Boolean       @default(true)
  systemAccount  Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          JournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId, type])
}

model JournalEntry {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  entryNumber    String
  entryDate      DateTime
  description    String
  status         JournalStatus @default(DRAFT)
  sourceModule   String
  sourceId       String?
  reversalOfId   String?       @db.Uuid
  createdById    String        @db.Uuid
  postedAt       DateTime?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId, status, entryDate])
}

model JournalLine {
  id              String        @id @default(uuid()) @db.Uuid
  journalEntryId  String        @db.Uuid
  ledgerAccountId String        @db.Uuid
  description     String?
  debit           Decimal       @default(0) @db.Decimal(19, 4)
  credit          Decimal       @default(0) @db.Decimal(19, 4)
  sortOrder       Int           @default(0)
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([ledgerAccountId])
}

model Integration {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @db.Uuid
  provider             String
  status               IntegrationStatus    @default(DISCONNECTED)
  syncDirection        SyncDirection        @default(PUSH)
  externalRealmId      String?
  encryptedCredentials String?
  settings             Json                 @default("{}")
  lastSyncAt           DateTime?
  lastError            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mappings             ExternalMapping[]
  syncRuns             IntegrationSyncRun[]

  @@unique([organizationId, provider])
}

model ExternalMapping {
  id            String      @id @default(uuid()) @db.Uuid
  integrationId String      @db.Uuid
  entityType    String
  localId       String      @db.Uuid
  externalId    String
  syncHash      String?
  lastSyncedAt  DateTime?
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, entityType, localId])
  @@unique([integrationId, entityType, externalId])
}

model IntegrationSyncRun {
  id             String        @id @default(uuid()) @db.Uuid
  integrationId  String        @db.Uuid
  status         String
  direction      SyncDirection
  processedCount Int           @default(0)
  failedCount    Int           @default(0)
  errorSummary   String?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  integration    Integration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String?       @db.Uuid
  provider        String
  externalEventId String
  eventType       String
  payload         Json
  status          String        @default("PENDING")
  attempts        Int           @default(0)
  processedAt     DateTime?
  lastError       String?
  createdAt       DateTime      @default(now())
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([status, createdAt])
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  eventId        String        @unique @default(uuid())
  organizationId String?       @db.Uuid
  actorUserId    String?       @db.Uuid
  sequence       BigInt?
  category       String        @default("BUSINESS")
  severity       String        @default("INFO")
  outcome        String        @default("SUCCESS")
  action         String
  entityType     String
  entityId       String?
  beforeJson     Json?
  afterJson      Json?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  requestMethod  String?
  requestPath    String?
  correlationId  String?
  previousHash   String?
  recordHash     String
  metadata       Json?
  retentionClass String        @default("STANDARD")
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor          User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sequence])
  @@index([organizationId, createdAt])
  @@index([category, severity, createdAt])
  @@index([requestId])
  @@index([entityType, entityId])
}

model AuditChainHead {
  organizationId String       @id @db.Uuid
  lastSequence   BigInt       @default(0)
  lastHash       String       @default("GENESIS")
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CustomFieldDefinition {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  objectType     String
  key            String
  label          String
  fieldType      String
  required       Boolean      @default(false)
  options        Json         @default("[]")
  validation     Json         @default("{}")
  sortOrder      Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, objectType, key])
}

model AutomationRule {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  name           String
  triggerType    String
  conditions     Json            @default("[]")
  actions        Json            @default("[]")
  active         Boolean         @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs           AutomationRun[]

  @@index([organizationId, active])
}

model AutomationRun {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @db.Uuid
  automationRuleId String         @db.Uuid
  status           String
  triggerPayload   Json           @default("{}")
  actionResults    Json           @default("[]")
  errorMessage     String?
  startedAt        DateTime       @default(now())
  completedAt      DateTime?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
  @@index([automationRuleId, status])
}

model Note {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  contactId      String?      @db.Uuid
  relatedType    String?
  relatedId      String?      @db.Uuid
  body           String
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId, relatedType, relatedId])
}

model Notification {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  type           String
  title          String
  body           String?
  actionUrl      String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
}

model TaxRate {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  jurisdiction   String?
  rate           Decimal      @db.Decimal(9, 6)
  compound       Boolean      @default(false)
  active         Boolean      @default(true)
  externalId     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

model TaxDocument {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @db.Uuid
  documentType       String
  taxYear            Int
  status             String       @default("DRAFT")
  provider           String?
  providerDocumentId String?
  filingConfirmation String?
  version            Int          @default(1)
  snapshotJson       Json
  storedFileId       String?      @db.Uuid
  generatedById      String?      @db.Uuid
  generatedAt        DateTime     @default(now())
  submittedAt        DateTime?
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType, taxYear, version])
  @@index([organizationId, status])
}

model ReconciliationSession {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  ledgerAccountId  String       @db.Uuid
  statementDate    DateTime
  statementBalance Decimal      @db.Decimal(19, 4)
  clearedBalance   Decimal      @default(0) @db.Decimal(19, 4)
  difference       Decimal      @default(0) @db.Decimal(19, 4)
  status           String       @default("OPEN")
  completedById    String?      @db.Uuid
  completedAt      DateTime?
