  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, statementDate])
}

model AccountingPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  startsOn       DateTime
  endsOn         DateTime
  status         String       @default("OPEN")
  lockedById     String?      @db.Uuid
  lockedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, startsOn, endsOn])
  @@index([organizationId, status, endsOn])
}

model BankAccount {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @db.Uuid
  ledgerAccountId  String?           @db.Uuid
  institutionName  String
  accountName      String
  accountType      String
  mask             String?
  currency         String            @default("USD")
  bookBalance      Decimal           @default(0) @db.Decimal(19, 4)
  availableBalance Decimal?          @db.Decimal(19, 4)
  connectionStatus String            @default("MANUAL")
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions     BankTransaction[]

  @@unique([organizationId, accountName])
  @@index([organizationId, connectionStatus])
}

model BankTransaction {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  bankAccountId     String       @db.Uuid
  postedAt          DateTime
  description       String
  amount            Decimal      @db.Decimal(19, 4)
  direction         String
